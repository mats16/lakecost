# Server / runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# DB backend: lakebase | sqlite | auto (default)
DB_BACKEND=sqlite
# Local dev SQLite path (defaults to ./data/finlake.db at repo root if unset)
# SQLITE_PATH=./data/finlake.db

# Databricks Apps environment (auto-injected when deployed; set locally to test)
DATABRICKS_HOST=dbc-1234567890123456.cloud.databricks.com
DATABRICKS_WORKSPACE_ID=1234567890123456
DATABRICKS_APP_NAME=
DATABRICKS_APP_PORT=8000
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=
# SQL_WAREHOUSE_ID=

# Local dev only: forged Databricks Apps headers
# The Vite dev proxy reads these and injects x-forwarded-* on /api requests so
# the API behaves the same way locally as it does behind the Databricks Apps
# reverse proxy. Leave blank in production.
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_USER_NAME=your-name
DATABRICKS_USER_ID=your-user-id
DATABRICKS_USER_EMAIL=your-email@example.com

# Lakebase (optional, set when DB_BACKEND=lakebase or auto)
# LAKEBASE_INSTANCE_NAME=
# PGHOST=
# PGDATABASE=finlake
# PGUSER=
# PGPORT=5432
# PGSSLMODE=require
# LAKEBASE_ENDPOINT=
