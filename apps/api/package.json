{
  "name": "@finlake/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/sql && cp src/sql/*.sql dist/sql/ && mkdir -p dist/notebooks && cp src/notebooks/*.ipynb dist/notebooks/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bcm-data-exports": "3.1035.0",
    "@aws-sdk/client-cost-explorer": "3.1035.0",
    "@aws-sdk/client-iam": "3.1035.0",
    "@aws-sdk/client-s3": "3.1035.0",
    "@databricks/appkit": "^0.28.0",
    "@databricks/sdk-experimental": "^0.16.0",
    "@finlake/db": "*",
    "@finlake/shared": "*",
    "express": "^4.21.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
